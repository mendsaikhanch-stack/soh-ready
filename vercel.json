{
  "crons": [
    {
      "path": "/api/cron/jobs-runner",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/reconcile?kind=claims",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/reconcile?kind=activation",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/reconcile?kind=merges",
      "schedule": "30 */6 * * *"
    },
    {
      "path": "/api/cron/reconcile?kind=auto-merge",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/reconcile?kind=notifications",
      "schedule": "*/5 * * * *"
    }
  ]
}
